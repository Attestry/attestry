### =========================================================
### Passport Permission APIs
### NOTE: Controller has no @PreAuthorize; runtime policy is validated in use case.
### =========================================================

@baseUrl = http://localhost:8080
@contentType = application/json
@accessToken = REPLACE_ACCESS_TOKEN
@passportId = REPLACE_PASSPORT_ID
@sellerGroupId = REPLACE_SELLER_GROUP_ID
@permissionId = REPLACE_PERMISSION_ID

### 1) Grant Permission
POST {{baseUrl}}/products/passports/{{passportId}}/permissions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "sellerGroupId": "{{sellerGroupId}}",
  "scope": "RETAIL_SALE",
  "expiresAt": null
}

### 2) Suspend Permission
PATCH {{baseUrl}}/products/passports/{{passportId}}/permissions/{{permissionId}}/suspend
Authorization: Bearer {{accessToken}}

### 3) Revoke Permission
DELETE {{baseUrl}}/products/passports/{{passportId}}/permissions/{{permissionId}}
Authorization: Bearer {{accessToken}}
