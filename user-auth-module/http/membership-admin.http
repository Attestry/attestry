### User Auth - Membership Admin APIs

@baseUrl = http://localhost:8080
@contentType = application/json
@accessToken = e1748f7a-85f7-418c-abb4-805e94af23a5
@tenantId = b32094dc-734c-4063-b289-a5882b061b72
@groupId = fd0ebf85-9d73-4e1d-b746-8ebfdf0929d6
@membershipId = b8851d3b-10fe-432a-9aeb-8a47105bb695
@invitationId = 495e6f55-bae7-4636-9f7e-338180be5e67
@roleCode = TENANT_OPERATOR
@templateCode = TEMPLATE_BRAND_WORK
@invitation-accessToken = 75ed2756-4ac5-4568-b997-504b8fa76625

### 1) Invite member
### Required scope: SCOPE_TENANT_INVITATION_CREATE
POST {{baseUrl}}/tenants/{{tenantId}}/admin/invitations
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "email": "operator1@attestry.io",
  "groupId": "{{groupId}}",
  "role": "STAFF"
}

### 2) Accept invitation
POST {{baseUrl}}/invitations/{{invitationId}}/accept
Authorization: Bearer {{invitation-accessToken}}

### 3) List memberships
### Required scope: SCOPE_TENANT_MEMBERSHIP_VIEW
GET {{baseUrl}}/tenants/{{tenantId}}/admin/memberships
Authorization: Bearer {{accessToken}}

### 4) Update membership status
### Required scope: SCOPE_TENANT_MEMBERSHIP_ENFORCE
PATCH {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/status
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "status": "ACTIVE"
}

### 5) List membership roles
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
GET {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/roles
Authorization: Bearer {{accessToken}}

### 6) List assignable roles for membership
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
GET {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/roles/available
Authorization: Bearer {{accessToken}}

### 7) List tenant available permission templates
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
GET {{baseUrl}}/tenants/{{tenantId}}/admin/permission-templates/available
Authorization: Bearer {{accessToken}}

### 8) Assign role
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
POST {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/roles/{{roleCode}}
Authorization: Bearer {{accessToken}}

### 9) Revoke role
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
DELETE {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/roles/{{roleCode}}
Authorization: Bearer {{accessToken}}

### 10) Apply permission template to membership
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
POST {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/permission-templates/{{templateCode}}/apply
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "reason": "grant for operation"
}

### 11) Revoke permission template from membership
### Required scope: SCOPE_TENANT_ROLE_ASSIGN
POST {{baseUrl}}/tenants/{{tenantId}}/admin/memberships/{{membershipId}}/permission-templates/{{templateCode}}/revoke
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "reason": "revoke temporary grant"
}
